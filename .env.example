# Minerva Configuration
# Copy this file to .env and customize for your environment

# Application settings
APP_NAME=minerva
APP_VERSION=1.0.0
APP_ENV=production

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Database
DATABASE_PATH=./data/minerva.db

# FreshRSS Configuration
FRESHRSS_BASE_URL=https://your-freshrss.example.com/api/fever.php?api
FRESHRSS_API_KEY=your-api-key-here
FRESHRSS_TIMEOUT=30

# Ollama Configuration  
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=300
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7

# SearXNG Configuration
SEARXNG_BASE_URL=https://your-searxng.example.com
SEARXNG_TIMEOUT=30

# Content Extractor
EXTRACTOR_USER_AGENT=Minerva/1.0
EXTRACTOR_TIMEOUT=30
EXTRACTOR_MAX_SIZE=10485760


# Koha Configuration
KOHA_BASE_URL=https://koha.your-library.example.com
KOHA_USERNAME=minerva
KOHA_PASSWORD=basic-auth-password-here

# Ntfy Configuration
NTFY_BASE_URL=https://nfty.your-notification.example.com
NTFY_TOPIC=minerva
NTFY_TOKEN=your-ntfy-token-here
NTFY_PRIORITY=5
NTFY_ENABLED=true
